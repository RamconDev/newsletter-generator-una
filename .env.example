## Example .env for Newsletter Generator UNA
# Use a PostgreSQL connection in production via `DATABASE_URL`.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# PostgreSQL connection string (required in Production)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
#DATABASE_URL=sqlite:///dev.db
# Flask secret key
SECRET_KEY=change_me

# File upload settings
UPLOAD_FOLDER=data
MAX_CONTENT_LENGTH=16777216  # bytes (16 MB)
MAX_FILE_SIZE=5242880       # bytes (5 MB)
ALLOWED_EXTENSIONS=rep
