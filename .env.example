# -----------------------------------------------------------------------------
# .env.example — Newsletter Generator UNA
# -----------------------------------------------------------------------------

FLASK_ENV=development
FLASK_DEBUG=True

# -- Base de datos ------------------------------------------------------------

DATABASE_URL=postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_DB

# -- Seguridad (MÍNIMO 16 caracteres cada uno) --------------------------------
# La app lanza RuntimeError al arrancar si alguno tiene menos de 16 caracteres
SECRET_KEY=dev-newsletter-secret-key-32chars-example
JWT_SECRET_KEY=dev-newsletter-jwt-secret-key-32chars-ex

# -- CORS (opcional en desarrollo, obligatorio en producción) -------------------
# CORS_ORIGINS=http://localhost:3000

# -- Proxy / IP real del cliente ----------------------------------------------
# Nº de proxies de confianza delante de la app para leer X-Forwarded-For.
# 0 = ignorar la cabecera (usar remote_addr). En dev, sin proxy, no afecta.
PROXY_FORWARDED_HOPS=1

# -- JWT (horas de expiración) ------------------------------------------------
JWT_EXP_HOURS=1
JWT_REFRESH_EXP_HOURS=24

# -- Archivos -----------------------------------------------------------------
UPLOAD_FOLDER=data
MAX_CONTENT_LENGTH=16777216
MAX_FILE_SIZE=5242880
ALLOWED_EXTENSIONS=rep

# -- URL prefix ---------------------------------------------------------------
API_PREFIX=/api
API_VERSION=v1